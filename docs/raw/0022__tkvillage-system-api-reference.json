{
  "document": {
    "id": "tkvillage.system-api-reference.v2",
    "title": "TkVillage System API Reference",
    "audience": {
      "primary": "LLMs and coding agents",
      "secondary": "human readers"
    }
  },
  "module": "tkvillage",
  "boundary": "TkVillage has no public config subsystem. Use lionscliapp or host-app facilities for application configuration.",
  "functions": {
    "declare_app": {
      "signature": "declare_app(spec)",
      "authority": "Runtime declaration.",
      "parameters": {
        "spec": "Application declaration dictionary."
      },
      "spec": {
        "name": "str. Required runtime/application name.",
        "shutdown-policy": "\"explicit\" | \"on-last-window-close\" | \"on-window-close\". Required.",
        "project-dir-name": "str. Standalone directory name. Required unless project-dir is supplied or lionscliapp is true.",
        "project-dir": "str | pathlib.Path. Optional explicit standalone project directory.",
        "project-root": "str | pathlib.Path | None. Optional parent for project-dir-name.",
        "lionscliapp": "bool. Optional. When true, defer project path readiness to ensure_ready().",
        "tick-interval-ms": "int | str. Optional; default 50.",
        "test-mode": "bool. Optional.",
        "create-root": "bool. Optional; defaults to false in lionscliapp mode, true otherwise.",
        "shutdown-window-kind": "str | None. Required for on-window-close.",
        "on-shutdown": "callable | None. Optional one function called once when shutdown begins."
      },
      "returns": "rt.g",
      "notes": [
        "Does not create project folders in lionscliapp mode.",
        "Registers debug windows.",
        "create_app() is deprecated; new code should use declare_app()."
      ]
    },
    "ensure_ready": {
      "signature": "ensure_ready()",
      "authority": "Runtime/project-directory readiness.",
      "returns": "rt.g",
      "behavior": [
        "If already ready, returns rt.g.",
        "In lionscliapp mode, imports lionscliapp.paths.get_project_root(), creates <project-root>/tkvillage, and stores host_project_dir and project_dir.",
        "In standalone mode, creates rt.g[\"project_dir\"]."
      ],
      "notes": [
        "Call at the top of lionscliapp commands that use TkVillage.",
        "run() calls ensure_ready() automatically."
      ]
    },
    "create_app": {
      "signature": "create_app(name=\"tkvillage\", project_dir_name=\".tkvillage\", project_root=None, tick_interval_ms=50, test_mode=False, create_root=True)",
      "authority": "Deprecated compatibility declaration.",
      "returns": "rt.g",
      "notes": [
        "Emits DeprecationWarning.",
        "Delegates to declare_app() with explicit shutdown policy."
      ]
    },
    "reset_app": {
      "signature": "reset_app()",
      "authority": "Runtime reset.",
      "returns": "rt.g",
      "notes": [
        "Preserves dictionary/list identities.",
        "Destroys an existing root if possible."
      ]
    },
    "run": {
      "signature": "run()",
      "authority": "Tk mainloop.",
      "behavior": "Calls ensure_ready(), ensures the hidden root, starts the tick loop, and enters tkinter.mainloop()."
    },
    "request_shutdown": {
      "signature": "request_shutdown(reason=None)",
      "authority": "Graceful shutdown request.",
      "parameters": {
        "reason": "Optional JSON-friendly value for logs and rt.g[\"shutdown_reason\"]."
      }
    },
    "shutdown": {
      "signature": "shutdown()",
      "authority": "Hard cleanup.",
      "behavior": "Calls the shutdown handler once if configured, stops ticking, destroys live windows and root, and marks the runtime not running."
    },
    "register_window_kind": {
      "signature": "register_window_kind(spec)",
      "authority": "Window-kind registry.",
      "spec": {
        "window-kind": "str. Required stable name.",
        "title": "str | None.",
        "multiplicity": "\"singleton\" | \"per-key\" | \"free-instance\" | \"embedded\" | \"modal\".",
        "create": "callable | None. create(record).",
        "make-initial-state": "callable | None. make_initial_state(key=None, payload=None).",
        "reduce-event": "callable | None. reduce_event(state, event) -> (new_state, effects).",
        "project": "callable | None. project(record).",
        "on-show": "callable | None. on_show(record).",
        "on-close": "callable | None. on_close(record), return False to cancel close.",
        "on-destroy": "callable | None. on_destroy(record).",
        "on-tick": "callable | None. on_tick(record) -> effects | None.",
        "debug-label": "str | None."
      }
    },
    "summon_window": {
      "signature": "summon_window(window_kind, key=None, payload=None)",
      "authority": "Window creation/reuse."
    },
    "raise_window": {
      "signature": "raise_window(window_id)",
      "authority": "Live window focus."
    },
    "close_window": {
      "signature": "close_window(window_id)",
      "authority": "Close request."
    },
    "destroy_window": {
      "signature": "destroy_window(window_id)",
      "authority": "Live window destruction."
    },
    "get_window": {
      "signature": "get_window(window_id)",
      "authority": "Live window read."
    },
    "list_windows": {
      "signature": "list_windows()",
      "authority": "Live window read."
    },
    "post_event": {
      "signature": "post_event(target_id, event)",
      "authority": "Event queue write."
    },
    "post_event_to_window": {
      "signature": "post_event_to_window(window_id, event)",
      "authority": "Event queue write."
    },
    "post_event_to_instance": {
      "signature": "post_event_to_instance(instance_key, event)",
      "authority": "Event queue write."
    },
    "post_event_to_kind": {
      "signature": "post_event_to_kind(window_kind, event)",
      "authority": "Event queue write."
    },
    "broadcast_event": {
      "signature": "broadcast_event(event)",
      "authority": "Event queue write."
    },
    "register_service_target": {
      "signature": "register_service_target(target_id, handler, state=None)",
      "authority": "Target registry."
    },
    "send_message": {
      "signature": "send_message(target_id, message, source_id=None)",
      "authority": "Message routing."
    },
    "send_message_to_window": {
      "signature": "send_message_to_window(window_id, message, source_id=None)",
      "authority": "Message routing."
    },
    "send_message_to_instance": {
      "signature": "send_message_to_instance(instance_key, message, source_id=None)",
      "authority": "Message routing."
    },
    "send_message_to_kind": {
      "signature": "send_message_to_kind(window_kind, message, source_id=None)",
      "authority": "Message routing."
    },
    "broadcast_message": {
      "signature": "broadcast_message(message, source_id=None)",
      "authority": "Message routing."
    },
    "route_effect": {
      "signature": "route_effect(effect, source_id=None)",
      "authority": "Effect routing."
    },
    "route_effects": {
      "signature": "route_effects(effects, source_id=None)",
      "authority": "Effect routing."
    },
    "tick_once": {
      "signature": "tick_once()",
      "authority": "Runtime heartbeat."
    },
    "run_ticks": {
      "signature": "run_ticks(count=1, update_tk=True)",
      "authority": "Testing helper."
    },
    "start_tick_loop": {
      "signature": "start_tick_loop()",
      "authority": "Tick scheduling."
    },
    "stop_tick_loop": {
      "signature": "stop_tick_loop()",
      "authority": "Tick scheduling."
    },
    "toggle_debug": {
      "signature": "toggle_debug()",
      "authority": "Debug UI."
    },
    "get_debug_snapshot": {
      "signature": "get_debug_snapshot(selected_window_id=None)",
      "authority": "Debug inspection."
    },
    "copy_debug_snapshot": {
      "signature": "copy_debug_snapshot(selected_window_id=None)",
      "authority": "Debug export."
    }
  }
}
